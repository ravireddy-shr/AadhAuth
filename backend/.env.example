APP_ENV=production
PORT=5000
MONGO_URL=mongodb://localhost:27017/
SECRET_KEY=replace-with-a-long-random-secret
CORS_ORIGINS=https://your-frontend-domain.com

# Optional bootstrap accounts. Leave disabled for a fully public deployment.
ENABLE_DEFAULT_ACCOUNTS=false
DEFAULT_CONDUCTOR_AADHAAR=
DEFAULT_CONDUCTOR_PASSWORD=
DEFAULT_GOVERNMENT_AADHAAR=
DEFAULT_GOVERNMENT_PASSWORD=

# Demo-only setting. Keep false for public deployment.
ENABLE_DEMO_SEEDING=false
